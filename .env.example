# ============================================================
# Server
# ============================================================
PORT=3001
NODE_ENV=development

# ============================================================
# Chatwoot
# API_TOKEN：Chatwoot → Profile Settings → Access Token
# ACCOUNT_ID：浏览器 URL 中的数字 /app/accounts/1
# INBOX_ID：Chatwoot → Settings → Inboxes → 创建 API 类型收件箱后获取
# ============================================================
CHATWOOT_BASE_URL=https://app.chatwoot.com
CHATWOOT_API_TOKEN=your-chatwoot-api-token
CHATWOOT_ACCOUNT_ID=158759
CHATWOOT_INBOX_ID=103296

# ============================================================
# AI Middleware 地址（用于上报连接状态）
# ============================================================
AI_MIDDLEWARE_URL=http://localhost:3000
AI_MIDDLEWARE_TOKEN=your-internal-api-bearer-token

# ============================================================
# WhatsApp 会话存储路径（扫码后凭证保存位置）
# ============================================================
WA_SESSION_DIR=./wa_session
